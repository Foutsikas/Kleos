# Auto detect text files and normalize line endings
* text=auto eol=lf

# Godot scene and resource files
*.tscn text eol=lf
*.tres text eol=lf
*.gd text eol=lf
*.cfg text eol=lf
*.import text eol=lf
*.gdshader text eol=lf

# Keep binary files as-is
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.wav binary
*.ogg binary
*.mp3 binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
