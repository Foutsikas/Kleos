[resource]
script = ExtResource("1_cdiag")
HeroAttackLines = Array[String](["Your blade finds its mark.", "A swift strike lands true.", "You press the attack with bronze resolve.", "The blow connects with practiced aim.", "Steel meets flesh in a burst of dust.", "You swing with the weight of your journey.", "A measured strike cuts through defense.", "The enemy staggers from your assault.", "Your arm does not falter."])
HeroCritLines = Array[String](["The gods guide your hand!", "A strike worthy of Achilles himself!", "Your blade sings with terrible purpose!", "Fortune favors the bold -- a devastating blow!", "The earth shakes with the force of your strike!", "A blow that would make Ares proud!", "The fates align -- your strike is true and terrible!"])
HeroDodgeLines = Array[String](["You sidestep with the grace of Hermes.", "The blow passes harmlessly through empty air.", "Quick feet spare you from harm.", "You read the attack and slip aside.", "The enemy strikes only shadow.", "Cunning reflexes turn aside the blow.", "You weave past the attack untouched."])
EnemyAttackLines = Array[String](["The {0} lashes out with fury.", "The {0} presses its attack.", "Claws and teeth find their mark as the {0} strikes.", "The {0} lunges with savage intent.", "A blow from the {0} finds you unprepared.", "The {0} retaliates with desperate strength.", "The {0} does not relent."])
EnemyAnticipationLines = Array[String](["The {0} circles warily.", "The {0} bares its teeth.", "The {0} tenses, ready to spring.", "The {0} watches for an opening.", "The {0} growls low, gathering strength."])
VictoryLines = Array[String](["The {0} falls. Your name grows in the telling.", "Another trial overcome. The {0} is no more.", "The dust settles. The {0} lies defeated.", "Where the {0} stood, only silence remains.", "The {0} yields to a greater warrior.", "This day belongs to you. The {0} is vanquished."])
VictorySubtitles = Array[String](["The deed is done", "Glory earned through struggle", "The trial is overcome", "A worthy victory"])
DefeatLines = Array[String](["The {0} proves the stronger... for now.", "You fall before the {0}. But heroes rise again.", "The {0} stands over you, victorious.", "Darkness takes you. The {0} endures.", "The {0} bests you. The wound will heal. The shame will not."])
DefeatSubtitles = Array[String](["The fates are cruel", "Not this day", "Strength was not enough", "The trial continues"])
DefeatConsolations = Array[String](["Even Herakles knew defeat before glory.", "The wound of failure births the strength of victory.", "Retreat is not cowardice. It is patience.", "The Fates weave threads of both triumph and trial.", "A hero who cannot fall cannot truly rise.", "Endure. The dawn follows even the longest night."])
