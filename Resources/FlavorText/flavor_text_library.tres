GenericOmenLines = Array[String](["A cold wind stirs the dust...", "The shadows grow restless...", "Your hand reaches for a weapon...", "The air tastes of iron...", "The hairs on your neck rise...", "An unnatural stillness settles...", "The ground trembles faintly...", "A crow circles overhead..."])
GenericArtisanLines = Array[String](["Another pair of hands joins the work...", "The workshop grows busier...", "Another craftsman takes up your cause...", "Word of honest work spreads..."])
